{
  "name": "movu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "npm ci && npm --prefix user-app ci && npm --prefix admin-dashboard ci",
    "bootstrap": "bash scripts/bootstrap.sh",
    "dev": "node scripts/dev.mjs",
    "start": "npm run dev",
    "seed": "docker compose exec -T backend python -m app.db.seed",
    "logs": "docker compose logs -f",
    "stop": "docker compose down",
    "ui:check": "node scripts/check-ui-usage.mjs",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
