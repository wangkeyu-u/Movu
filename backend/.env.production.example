APP_NAME=MovU Carpooling API
ENVIRONMENT=production
DATABASE_URL=mysql+pymysql://movu:${MOVU_DB_PASSWORD}@mysql:3306/movu_carpooling
JWT_SECRET_KEY=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
EMAIL_VERIFICATION_EXPIRE_MINUTES=1440
FRONTEND_BASE_URL=https://app.your-movu-domain.com
CORS_ORIGINS=https://admin.your-movu-domain.com,https://app.your-movu-domain.com
PUBLIC_API_BASE_URL=https://api.your-movu-domain.com/api
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=movu-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=no-reply@your-movu-domain.com
SMTP_USE_TLS=true
OSRM_BASE_URL=https://router.project-osrm.org
SERVICE_AREA_CENTER_LATITUDE=3.0646454
SERVICE_AREA_CENTER_LONGITUDE=101.6159384
SERVICE_AREA_RADIUS_KM=30
RATE_LIMIT_REQUESTS=600
RATE_LIMIT_WINDOW_SECONDS=60
